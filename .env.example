# Environment Variables for Ticket Booking Application

# JWT Configuration
JWT_SECRET=your-256-bit-secret-key-change-this-in-production
JWT_EXPIRATION=86400

# Database Configuration
DB_URL=jdbc:mysql://localhost:3306/datvemovie?useSSL=false&serverTimezone=UTC&allowPublicKeyRetrieval=true
DB_USERNAME=root
DB_PASSWORD=

# Server Configuration
SERVER_PORT=8080

# Redis Configuration (for rate limiting and refresh tokens)
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=

# Spring Boot Actuator
ACTUATOR_ENDPOINTS_WEB_EXPOSE=health,info,metrics

# Logging
LOG_LEVEL=INFO